(version 1)

(rule BGA
	(constraint clearance (min 0.1mm))
	(constraint track_width (min 0.1mm))
	(constraint hole_clearance (min 0.15mm))
	(condition "A.intersectsArea('BGA')")
)

(rule clearance_0201
	(constraint clearance (min 0.17mm))
	(condition "A.memberOfFootprint('BR_Passives:*_0201_0603Metric')")
)

(rule clearance_SOT-963
	(constraint clearance (min 0.1mm))
	(condition "A.memberOfFootprint('BR_SOT:SOT-963')"))
